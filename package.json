{
  "name": "@clarity-fintech/clrty-quality-gate",
  "version": "0.1.0",
  "description": "SonarQube-oriented quality gate and CLRTY-1 security checks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clrty-gate": "dist/gate.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "CLRTY_RPC_SMOKE=0 vitest run",
    "gate": "tsx src/gate.ts",
    "smoke": "node scripts/smoke-clrty1.mjs",
    "test:live": "CLRTY_LIVE=1 vitest run tests/clrty1_live.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0"
}
